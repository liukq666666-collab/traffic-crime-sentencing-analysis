# 生成最终综合分析图表
fig, axes = plt.subplots(2, 2, figsize=(16, 12))

# 1. ROC曲线对比
ax1 = axes[0, 0]
for model_name, prob, color in [
    ('逻辑回归', lr_prob, '#3498db'),
    ('随机森林', rf_prob, '#2ecc71'),
    ('梯度提升', gb_prob, '#e74c3c')
]:
    fpr, tpr, _ = roc_curve(y_test, prob)
    auc = roc_auc_score(y_test, prob)
    ax1.plot(fpr, tpr, label=f'{model_name} (AUC={auc:.3f})', color=color, linewidth=2)
ax1.plot([0, 1], [0, 1], 'k--', alpha=0.3)
ax1.set_xlabel('假阳性率', fontsize=12)
ax1.set_ylabel('真阳性率', fontsize=12)
ax1.set_title('模型ROC曲线对比', fontsize=14, fontweight='bold')
ax1.legend(loc='lower right', fontsize=11)
ax1.grid(True, alpha=0.3)

# 2. 特征重要性 (随机森林)
ax2 = axes[0, 1]
top_features = feature_importance.head(8)
colors = plt.cm.RdYlGn(np.linspace(0.2, 0.8, len(top_features)))[::-1]
