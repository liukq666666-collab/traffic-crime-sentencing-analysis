             f'{val:.3f}', va='center', fontsize=10)

# 3. 谅解+赔偿组合对缓刑率的影响
ax3 = axes[1, 0]
combo_data = df.groupby(['是否赔偿', '是否谅解'])['是否缓刑'].mean() * 100
combo_labels = ['未赔偿\n未谅解', '已赔偿\n未谅解', '未赔偿\n已谅解', '已赔偿\n已谅解']
