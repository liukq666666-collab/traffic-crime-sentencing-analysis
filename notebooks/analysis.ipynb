from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import classification_report, roc_auc_score, roc_curve
import warnings
warnings.filterwarnings('ignore')

# 数据预处理
df_model = df.copy()

# 创建目标变量：是否缓刑（缓刑>0则为1）
df_model['是否缓刑'] = (df_model['缓刑'] > 0).astype(int)

# 处理缺失值
df_model['出生年份'] = df_model['出生年份'].fillna(df_model['出生年份'].median())

# 计算年龄（假设判决年份为2019年，从案号推断）
df_model['年龄'] = 2019 - df_model['出生年份']

# 选择特征变量
features = ['性别', '年龄', '文化水平', '是否逃逸', '是否自首', '是否谅解', '是否赔偿', 
            '死亡', '总受伤人数', '重伤人数', '轻伤人数', '责任划分', '有期徒刑']

# 过滤有效数据
df_clean = df_model[features + ['是否缓刑']].dropna()
print(f"建模用数据量: {len(df_clean):,} 份")

X = df_clean[features]
y = df_clean['是否缓刑']

# 划分训练集和测试集
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42, stratify=y)

# 标准化
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

print(f"训练集: {len(X_train):,}, 测试集: {len(X_test):,}")
print(f"缓刑率: {y.mean()*100:.1f}%")



# 训练多个模型

# 1. 逻辑回归
lr = LogisticRegression(max_iter=1000, random_state=42, class_weight='balanced')
lr.fit(X_train_scaled, y_train)
lr_pred = lr.predict(X_test_scaled)
lr_prob = lr.predict_proba(X_test_scaled)[:, 1]
lr_auc = roc_auc_score(y_test, lr_prob)

# 2. 随机森林
rf = RandomForestClassifier(n_estimators=200, max_depth=10, random_state=42, class_weight='balanced')
rf.fit(X_train, y_train)
rf_pred = rf.predict(X_test)
rf_prob = rf.predict_proba(X_test)[:, 1]
rf_auc = roc_auc_score(y_test, rf_prob)

# 3. XGBoost (使用GradientBoosting)
gb = GradientBoostingClassifier(n_estimators=200, max_depth=5, learning_rate=0.1, random_state=42)
gb.fit(X_train, y_train)
gb_pred = gb.predict(X_test)
gb_prob = gb.predict_proba(X_test)[:, 1]
gb_auc = roc_auc_score(y_test, gb_prob)

print("="*60)
print("模型性能对比 (AUC-ROC)")
print("="*60)
print(f"逻辑回归 (Logistic Regression): {lr_auc:.4f}")
print(f"随机森林 (Random Forest):       {rf_auc:.4f}")
print(f"梯度提升 (Gradient Boosting):   {gb_auc:.4f}")

# 特征重要性 (随机森林)
feature_importance = pd.DataFrame({
    '特征': features,
    '重要性': rf.feature_importances_
}).sort_values('重要性', ascending=False)

print("\n" + "="*60)
print("随机森林 - 特征重要性排名")
print("="*60)
for idx, row in feature_importance.iterrows():
    print(f"{row['特征']:12s}: {row['重要性']:.4f}")



# 逻辑回归系数分析（可解释性最强）
lr_coef = pd.DataFrame({
    '特征': features,
    '系数': lr.coef_[0],
    'OR值': np.exp(lr.coef_[0])
}).sort_values('OR值', ascending=False)

print("="*60)
print("逻辑回归 - 变量对缓刑概率的影响 (OR值)")
print("="*60)
print("OR>1: 增加缓刑概率 | OR<1: 降低缓刑概率")
print("-"*60)
for idx, row in lr_coef.iterrows():
    direction = "↑ 增加" if row['OR值'] > 1 else "↓ 降低"
    print(f"{row['特征']:12s}: OR={row['OR值']:.3f} ({direction})")

# 计算具体场景的概率变化
print("\n" + "="*60)
print("关键发现：赔偿+谅解的协同效应")
print("="*60)

# 基线：无赔偿、无谅解、无自首、无逃逸、1人死亡、全部责任、12个月刑期
baseline = X.mean().values.copy()
# 设置基线条件
baseline_dict = dict(zip(features, baseline))
baseline_dict['是否赔偿'] = 0
baseline_dict['是否谅解'] = 0
baseline_dict['是否自首'] = 0
baseline_dict['是否逃逸'] = 0
baseline_dict['死亡'] = 1
baseline_dict['责任划分'] = 3
baseline_dict['有期徒刑'] = 12

# 转换为数组并标准化
baseline_array = np.array([baseline_dict[f] for f in features]).reshape(1, -1)
baseline_scaled = scaler.transform(baseline_array)
base_prob = lr.predict_proba(baseline_scaled)[0, 1]

print(f"基线概率 (无赔偿、无谅解、无自首、1人死亡、全部责任、12月刑期): {base_prob*100:.1f}%")

# 改变单一变量
scenarios = [
    ('仅赔偿', {'是否赔偿': 1}),
    ('仅谅解', {'是否谅解': 1}),
    ('仅自首', {'是否自首': 1}),
    ('赔偿+谅解', {'是否赔偿': 1, '是否谅解': 1}),
    ('赔偿+谅解+自首', {'是否赔偿': 1, '是否谅解': 1, '是否自首': 1}),
    ('赔偿+谅解+自首+主要责任', {'是否赔偿': 1, '是否谅解': 1, '是否自首': 1, '责任划分': 2}),
]

for name, changes in scenarios:
    scenario_dict = baseline_dict.copy()
    for k, v in changes.items():
        scenario_dict[k] = v
    scenario_array = np.array([scenario_dict[f] for f in features]).reshape(1, -1)
    scenario_scaled = scaler.transform(scenario_array)
    prob = lr.predict_proba(scenario_scaled)[0, 1]
    diff = prob - base_prob
    print(f"  {name:20s}: {prob*100:.1f}% (提升 {diff*100:+.1f}个百分点)")



# 重新审视逻辑回归系数 - 检查是否存在多重共线性问题
# 有期徒刑和缓刑可能存在高度相关，需要重新建模

from statsmodels.stats.outliers_influence import variance_inflation_factor

# 计算VIF
vif_data = pd.DataFrame()
vif_data['特征'] = features
vif_data['VIF'] = [variance_inflation_factor(X.values, i) for i in range(len(features))]
print("VIF (方差膨胀因子) - VIF>10表示严重多重共线性:")
print(vif_data.sort_values('VIF', ascending=False))

# 有期徒刑和缓刑高度相关，移除有期徒刑后重新建模
features_v2 = ['性别', '年龄', '文化水平', '是否逃逸', '是否自首', '是否谅解', '是否赔偿', 
               '死亡', '总受伤人数', '重伤人数', '轻伤人数', '责任划分']

X2 = df_clean[features_v2]
X2_train, X2_test, y2_train, y2_test = train_test_split(X2, y, test_size=0.3, random_state=42, stratify=y)

scaler2 = StandardScaler()
X2_train_scaled = scaler2.fit_transform(X2_train)
X2_test_scaled = scaler2.transform(X2_test)

# 重新训练逻辑回归
lr2 = LogisticRegression(max_iter=1000, random_state=42, class_weight='balanced')
lr2.fit(X2_train_scaled, y2_train)
lr2_prob = lr2.predict_proba(X2_test_scaled)[:, 1]
lr2_auc = roc_auc_score(y2_test, lr2_prob)

print(f"\n移除'有期徒刑'后逻辑回归 AUC: {lr2_auc:.4f}")

# 新的OR值
lr2_coef = pd.DataFrame({
    '特征': features_v2,
    '系数': lr2.coef_[0],
    'OR值': np.exp(lr2.coef_[0])
}).sort_values('OR值', ascending=False)

print("\n" + "="*60)
print("修正后逻辑回归 - 变量对缓刑概率的影响 (OR值)")
print("="*60)
for idx, row in lr2_coef.iterrows():
    direction = "↑ 增加缓刑概率" if row['OR值'] > 1 else "↓ 降低缓刑概率"
    print(f"{row['特征']:12s}: OR={row['OR值']:.3f} ({direction})")



# 生成更精细的分析 - 赔偿金额与缓刑的关系（用是否赔偿作为代理变量）
# 以及地区差异分析

# 1. 按地区分析缓刑率
region_stats = df.groupby('规范地区').agg({
    '是否缓刑': lambda x: (x > 0).mean() * 100,
    '案号': 'count',
    '是否赔偿': 'mean',
    '是否谅解': 'mean',
    '有期徒刑': 'mean'
}).rename(columns={'案号': '案件数', '是否缓刑': '缓刑率', 
                   '是否赔偿': '赔偿率', '是否谅解': '谅解率', '有期徒刑': '平均刑期'})

region_stats = region_stats[region_stats['案件数'] >= 50].sort_values('缓刑率', ascending=False)

print("="*80)
print("各地区缓刑率排名 (案件数≥50)")
print("="*80)
print(region_stats.head(15).to_string())

print("\n" + "="*80)
print("各地区缓刑率排名 (最低)")
print("="*80)
print(region_stats.tail(10).to_string())



# 重新创建是否缓刑变量
df['是否缓刑'] = (df['缓刑'] > 0).astype(int)

# 按地区分析缓刑率
region_stats = df.groupby('规范地区').agg({
    '是否缓刑': lambda x: (x > 0).mean() * 100,
    '案号': 'count',
    '是否赔偿': 'mean',
    '是否谅解': 'mean',
    '有期徒刑': 'mean'
}).rename(columns={'案号': '案件数', '是否缓刑': '缓刑率', 
                   '是否赔偿': '赔偿率', '是否谅解': '谅解率', '有期徒刑': '平均刑期'})

region_stats = region_stats[region_stats['案件数'] >= 50].sort_values('缓刑率', ascending=False)

print("="*80)
